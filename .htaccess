RewriteRule ^documents/([^/]+)/?$ index.php?p=verdoc&b=$1 [L,QSA]
RewriteRule ^documents/?$ index.php?p=listadocs [L,QSA]

# Inventory canonicalization
RewriteRule ^inventory/item/([^/]+)/?$ /inventory/items/$1? [R=301,L]
RewriteRule ^inventory/items/?$ /inventory? [R=301,L]
RewriteRule ^inventory/type/?$ /inventory? [R=301,L]
RewriteRule ^inventory/(?!type(?:/|$)|items?(?:/|$))([^/]+)/?$ /inventory/type/$1? [R=301,L,NC]

RewriteRule ^inventory/type/([^/]+)/?$ index.php?p=inv_type&t=$1 [L,QSA]
RewriteRule ^inventory/([^/]+)/([^/]+)/?$ index.php?p=verobj&b=$2&t=$1 [L,QSA]
RewriteRule ^inventory/items/([^/]+)/?$ index.php?p=verobj&b=$1 [L,QSA]
RewriteRule ^inventory/?$ index.php?p=inv [L,QSA]

