RewriteCond %{THE_REQUEST} \s+/(?:index\.php)?\?p=tipototm&b=([0-9]+)\s [NC]
RewriteRule ^(?:index\.php)?$ /powers/totem/type/%1? [R=301,L]

RewriteCond %{THE_REQUEST} \s+/(?:index\.php)?\?p=muestradisc&b=([0-9]+)\s [NC]
