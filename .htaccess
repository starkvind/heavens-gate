# Production error settings (prefer php.ini or vhost config when possible)
php_value error_reporting 0
php_flag display_errors Off
php_flag display_startup_errors Off

Options -Indexes

<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /

# ==============================
# Security
# ==============================
RewriteRule (^|/)\.(?:git|svn|hg)(?:/|$) index.php?p=error404 [L,NC,QSA]
RewriteRule (^|/)(?:\.(?:gitignore|gitattributes|env(?:\..*)?)|config\.env(?:\..*)?)$ index.php?p=error404 [L,NC,QSA]
RewriteRule ^app(?:/|$) index.php?p=error404 [L,NC,QSA]
RewriteRule (^|/)(?:README|TECHNICAL_DOCUMENTATION|TELEGRAM_BOT_BACKEND_GUIDE)\.md$ index.php?p=error404 [L,NC,QSA]
RewriteRule (^|/)(?:composer\.(?:json|lock)|phpunit\.xml(?:\.dist)?|dump-[^/]+\.sql|check_encoding\.ps1)$ index.php?p=error404 [L,NC,QSA]
RewriteRule (^|/)admin_upgrade_notes(?:/|$) index.php?p=error404 [L,NC,QSA]

# ==============================
# Existing files and folders
# ==============================
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# ==============================
# Aliases to /public
# ==============================
RewriteRule ^img/(.*)$ public/img/$1 [L]
RewriteRule ^sounds/(.*)$ public/sounds/$1 [L]

# ==============================
# Front controller
# ==============================
RewriteRule ^ index.php [L,QSA]

</IfModule>
