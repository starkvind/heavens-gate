RewriteRule ^sep/snippet_forum_hg\.php$ /forum/message [R=301,L,QSA,NC]

RewriteRule ^tools/keygen/?$ index.php?p=keygen [L,QSA]
RewriteRule ^tools/crop/?$ index.php?p=crop [L,QSA]
RewriteRule ^tools/dice/?$ index.php?p=dados [L,QSA]
RewriteRule ^tools/csp/?$ index.php?p=csp [L,QSA]
RewriteRule ^tools/garou-name-generator/?$ index.php?p=garou_name_gen [L,QSA]
RewriteRule ^tools/forum-avatar/?$ index.php?p=forum_avatar_tool [L,QSA]
RewriteRule ^tools/forum-topic-viewer/?$ index.php?p=forum_topic_viewer [L,QSA]
RewriteRule ^tools/combat-simulator/result/?$ index.php?p=combat_simulator_result [L,QSA]
RewriteRule ^tools/combat-simulator/log/([0-9]+)/?$ index.php?p=combat_simulator_log&b=$1 [L,QSA]
RewriteRule ^tools/combat-simulator/log/?$ index.php?p=combat_simulator_logs [L,QSA]
RewriteRule ^tools/combat-simulator/scores/?$ index.php?p=combat_simulator_scores [L,QSA]
RewriteRule ^tools/combat-simulator/weapons/?$ index.php?p=combat_simulator_weapons [L,QSA]
RewriteRule ^tools/combat-simulator/tournament/?$ index.php?p=combat_simulator_tournament [L,QSA]
RewriteRule ^tools/combat-simulator/?$ index.php?p=combat_simulator [L,QSA]

RewriteRule ^ajax/tooltip/?$ index.php?p=tooltip [L,QSA]
RewriteRule ^ajax/mentions/?$ index.php?p=mentions [L,QSA]
RewriteRule ^ajax/epis/?$ index.php?p=mentions&type=episode [L,QSA]

# ==============================
# Fallback 404
# ==============================
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php?p=error404 [L,QSA]

</IfModule>

